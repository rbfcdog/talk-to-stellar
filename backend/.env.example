# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase Configuration  
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Stellar Configuration
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# API / Internal Auth
PORT=3001
INTERNAL_API_SECRET=change-me

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app

# ===== TWILIO CONFIGURATION (for WhatsApp Webhook) =====
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# ===== AGENT API CONFIGURATION =====
# URL where the TalkToStellar agent is running
PYTHON_API_URL=http://localhost:8000/api/actions/query

# Timeout for waiting agent response (milliseconds)
PYTHON_API_TIMEOUT=30000